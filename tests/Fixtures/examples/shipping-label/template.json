{
  "title": "Shipping Label",
  "version": 1,
  "config": {
    "page": {
      "format": "ParcelLabel4x6",
      "locale": "en_US",
      "margins": {
        "top": 3,
        "right": 3,
        "bottom": 3,
        "left": 3
      },
      "pageNumbers": {
        "enabled": false,
        "position": "center"
      }
    },
    "typography": {
      "family": "Inter",
      "size": 8
    }
  },
  "rows": [
    {
      "blocks": [
        {
          "type": "key-value",
          "id": "carrier",
          "config": {
            "width": "45%",
            "fields": [
              {
                "key": "name",
                "label": "Carrier"
              },
              {
                "key": "shipDate",
                "label": "Ship date"
              }
            ]
          }
        },
        {
          "type": "key-value",
          "id": "service",
          "config": {
            "width": "55%",
            "align": "right",
            "fields": [
              {
                "key": "level",
                "label": "Service"
              },
              {
                "key": "weight",
                "label": "Weight"
              }
            ]
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "key-value",
          "id": "recipient",
          "config": {
            "width": "100%",
            "fields": [
              {
                "key": "name",
                "label": "Ship to"
              },
              {
                "key": "address",
                "label": "Address"
              },
              {
                "key": "cityStatePostal",
                "label": "City / state"
              }
            ]
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "key-value",
          "id": "sender",
          "config": {
            "width": "100%",
            "fields": [
              {
                "key": "name",
                "label": "From"
              },
              {
                "key": "address",
                "label": "Return address"
              },
              {
                "key": "cityStatePostal",
                "label": "City / state"
              }
            ]
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "key-value",
          "id": "tracking",
          "config": {
            "width": "58%",
            "fields": [
              {
                "key": "number",
                "label": "Tracking"
              }
            ]
          }
        },
        {
          "type": "key-value",
          "id": "routing-code",
          "config": {
            "width": "42%",
            "align": "right",
            "fields": [
              {
                "key": "code",
                "label": "Routing"
              },
              {
                "key": "hub",
                "label": "Hub"
              }
            ]
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "image",
          "id": "barcode",
          "config": {
            "width": "100%",
            "maxHeight": 72
          }
        }
      ]
    }
  ],
  "data": {
    "example": {
      "carrier": {
        "name": "UPS",
        "shipDate": "2026-05-27"
      },
      "service": {
        "level": "Ground Commercial",
        "weight": "2.4 kg"
      },
      "recipient": {
        "name": "Jordan Lee",
        "address": "742 Evergreen Terrace",
        "cityStatePostal": "Springfield, IL 62704"
      },
      "sender": {
        "name": "PDF UA Kit GmbH",
        "address": "Musterstrasse 1",
        "cityStatePostal": "10115 Berlin"
      },
      "tracking": {
        "number": "1Z999AA10123456784"
      },
      "routing-code": {
        "code": "IL 627 9-04",
        "hub": "ORD-03"
      }
    },
    "constants": {
      "barcode": {
        "src": "data:image/svg+xml;base64,",
        "alt": "Barcode for tracking number 1Z999AA10123456784"
      }
    }
  }
}
