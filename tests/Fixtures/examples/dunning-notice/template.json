{
  "title": "Dunning Notice",
  "version": 1,
  "config": {
    "page": {
      "format": "A4",
      "locale": "de_DE",
      "margins": {
        "top": 20,
        "right": 20,
        "bottom": 20,
        "left": 25
      },
      "pageNumbers": {
        "enabled": true,
        "position": "center"
      },
      "footer": {
        "repeat": true,
        "rows": [
          {
            "blocks": [
              {
                "type": "text",
                "id": "footer-legal",
                "config": {
                  "width": "68%"
                }
              },
              {
                "type": "key-value",
                "id": "footer-meta",
                "config": {
                  "width": "32%",
                  "align": "right",
                  "fields": [
                    {
                      "key": "registration",
                      "label": "Registry"
                    },
                    {
                      "key": "taxNumber",
                      "label": "Tax no."
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    "typography": {
      "family": "Inter",
      "size": 10
    }
  },
  "rows": [
    {
      "blocks": [
        {
          "type": "key-value",
          "id": "creditor",
          "config": {
            "width": "58%",
            "fields": [
              {
                "key": "name",
                "label": "Creditor"
              },
              {
                "key": "address",
                "label": "Address"
              },
              {
                "key": "contact",
                "label": "Contact"
              },
              {
                "key": "email",
                "label": "Email"
              },
              {
                "key": "vatId",
                "label": "VAT ID"
              }
            ]
          }
        },
        {
          "type": "key-value",
          "id": "notice-meta",
          "config": {
            "width": "42%",
            "align": "right",
            "fields": [
              {
                "key": "noticeNumber",
                "label": "Notice number"
              },
              {
                "key": "noticeDate",
                "label": "Notice date"
              },
              {
                "key": "customerNumber",
                "label": "Customer number"
              },
              {
                "key": "paymentDueDate",
                "label": "Payment due"
              }
            ]
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "key-value",
          "id": "debtor",
          "config": {
            "width": "58%",
            "fields": [
              {
                "key": "name",
                "label": "Debtor"
              },
              {
                "key": "address",
                "label": "Address"
              },
              {
                "key": "email",
                "label": "Email"
              },
              {
                "key": "reference",
                "label": "Debtor reference"
              }
            ]
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "heading",
          "id": "heading",
          "config": {
            "level": 1
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "text",
          "id": "notice-text",
          "config": {
            "width": "100%"
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "table",
          "id": "overdue-invoices",
          "config": {
            "style": "striped",
            "columns": [
              {
                "key": "invoiceNumber",
                "label": "Invoice no.",
                "align": "left",
                "width": "24%"
              },
              {
                "key": "issueDate",
                "label": "Issue date",
                "align": "left",
                "width": "18%"
              },
              {
                "key": "dueDate",
                "label": "Due date",
                "align": "left",
                "width": "18%"
              },
              {
                "key": "daysOverdue",
                "label": "Days overdue",
                "align": "right",
                "width": "18%"
              },
              {
                "key": "amount",
                "label": "Amount",
                "align": "right",
                "width": "22%"
              }
            ],
            "numberRows": false
          }
        }
      ]
    },
    {
      "blocks": [
        {
          "type": "text",
          "id": "closing-note",
          "config": {
            "width": "54%"
          }
        },
        {
          "type": "key-value",
          "id": "payment",
          "config": {
            "width": "46%",
            "align": "right",
            "fields": [
              {
                "key": "amountDue",
                "label": "Amount due"
              },
              {
                "key": "bank",
                "label": "Bank"
              },
              {
                "key": "iban",
                "label": "IBAN"
              },
              {
                "key": "bic",
                "label": "BIC"
              },
              {
                "key": "reference",
                "label": "Payment reference"
              }
            ]
          }
        }
      ]
    }
  ],
  "data": {
    "example": {
      "notice-meta": {
        "noticeNumber": "MA-2026-00018",
        "noticeDate": "2026-04-24",
        "customerNumber": "K-10482",
        "paymentDueDate": "2026-05-02"
      },
      "debtor": {
        "name": "Musterkunde AG",
        "address": "Käuferweg 2, 80331 München, DE",
        "email": "accounting@musterkunde.example",
        "reference": "04011000-12345-67"
      },
      "notice-text": {
        "text": "According to our records, the invoices listed below remain unpaid after their agreed due dates. Please arrange payment of the outstanding balance no later than 2026-05-02. If payment has already been made, please disregard this reminder and send us the remittance advice."
      },
      "overdue-invoices": [
        {
          "invoiceNumber": "RE-2026-001104",
          "issueDate": "2026-02-03",
          "dueDate": "2026-03-04",
          "daysOverdue": "51",
          "amount": "2.856,00 €"
        },
        {
          "invoiceNumber": "RE-2026-001137",
          "issueDate": "2026-02-21",
          "dueDate": "2026-03-23",
          "daysOverdue": "32",
          "amount": "1.975,40 €"
        }
      ],
      "payment": {
        "amountDue": "4.831,40 €",
        "reference": "MA-2026-00018"
      }
    },
    "defaults": {
      "closing-note": {
        "text": "Please contact accounting@pdfua-kit.example if you need a copy invoice or want to clarify an already initiated payment."
      },
      "payment": {
        "bank": "Musterbank Berlin",
        "iban": "DE89370400440532013000",
        "bic": "COBADEFFXXX"
      }
    },
    "constants": {
      "heading": {
        "text": "Dunning notice / Payment reminder"
      },
      "creditor": {
        "name": "PDF UA Kit GmbH",
        "address": "Musterstraße 1, 10115 Berlin, DE",
        "contact": "Max Mustermann",
        "email": "billing@pdfua-kit.example",
        "vatId": "DE123456789"
      },
      "footer-legal": {
        "text": "PDF UA Kit GmbH · Musterstraße 1 · 10115 Berlin · Germany · Please quote the notice number with every payment."
      },
      "footer-meta": {
        "registration": "HRB 123456 B",
        "taxNumber": "DE123456789"
      }
    }
  }
}
