{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://pdfuakit.com/schemas/pdf-ua-client-template-v1.json",
    "type": "object",
    "required": [
        "version",
        "config",
        "rows"
    ],
    "properties": {
        "version": {
            "const": 1,
            "type": "integer"
        },
        "config": {
            "$ref": "#/$defs/templateConfig"
        },
        "rows": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/row"
            }
        }
    },
    "$defs": {
        "spacingConfig": {
            "type": "object",
            "properties": {
                "top": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "right": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "bottom": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                },
                "left": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "minimum": 0
                }
            },
            "additionalProperties": false
        },
        "pageNumbersConfig": {
            "type": "object",
            "properties": {
                "position": {
                    "type": "string",
                    "default": "center"
                }
            },
            "additionalProperties": false
        },
        "pageConfig": {
            "type": "object",
            "properties": {
                "format": {
                    "type": "string",
                    "enum": [
                        "A4",
                        "A5",
                        "Letter",
                        "Legal"
                    ],
                    "default": "A4"
                },
                "locale": {
                    "type": "string",
                    "default": "de_DE"
                },
                "margins": {
                    "$ref": "#/$defs/spacingConfig"
                },
                "pageNumbers": {
                    "$ref": "#/$defs/pageNumbersConfig"
                }
            },
            "additionalProperties": false
        },
        "typographyConfig": {
            "type": "object",
            "properties": {
                "family": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "Inter",
                        "Georgia",
                        null
                    ],
                    "enumNames": [
                        "Inter",
                        "Georgia",
                        "Default"
                    ]
                },
                "size": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "weight": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "enum": [
                        300,
                        400,
                        500,
                        600,
                        700
                    ]
                },
                "align": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "left",
                        "center",
                        "right"
                    ]
                },
                "color": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "additionalProperties": false
        },
        "templateConfig": {
            "type": "object",
            "properties": {
                "page": {
                    "$ref": "#/$defs/pageConfig"
                },
                "typography": {
                    "$ref": "#/$defs/typographyConfig"
                }
            },
            "additionalProperties": false
        },
        "blockBase": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                }
            }
        },
        "blockConfig": {
            "type": "object",
            "properties": {
                "typography": {
                    "$ref": "#/$defs/typographyConfig"
                },
                "spacing": {
                    "$ref": "#/$defs/spacingConfig"
                },
                "width": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "title": "Width"
                },
                "align": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "left",
                        "center",
                        "right"
                    ],
                    "title": "Alignment"
                }
            }
        },
        "headingConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "level": {
                    "type": "integer",
                    "title": "Level",
                    "minimum": 1,
                    "maximum": 6,
                    "default": 2
                }
            },
            "unevaluatedProperties": false
        },
        "headingProps": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string",
                    "examples": [
                        "Invoice 2026-001"
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "text"
            ],
            "title": "Heading",
            "description": "A section heading (h1\u2013h6)."
        },
        "headingBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "heading",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/headingConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "textProps": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string",
                    "examples": [
                        "Thank you for your business."
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "text"
            ],
            "title": "Text",
            "description": "A paragraph of text."
        },
        "textBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "text",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/blockConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "htmlProps": {
            "type": "object",
            "properties": {
                "html": {
                    "type": "string",
                    "examples": [
                        "<p>Custom HTML</p>"
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "html"
            ],
            "title": "HTML",
            "description": "Raw HTML escape hatch."
        },
        "htmlBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "html",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/blockConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "imageConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "maxHeight": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 60
                }
            },
            "unevaluatedProperties": false
        },
        "imageProps": {
            "type": "object",
            "properties": {
                "src": {
                    "type": "string",
                    "examples": [
                        "https://placehold.co/200x80"
                    ]
                },
                "alt": {
                    "type": "string",
                    "examples": [
                        "Logo"
                    ],
                    "default": ""
                }
            },
            "additionalProperties": false,
            "required": [
                "src"
            ],
            "title": "Image"
        },
        "imageBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "image",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/imageConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "spacerConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "height": {
                    "type": "integer",
                    "minimum": 0,
                    "default": 5
                }
            },
            "unevaluatedProperties": false
        },
        "spacerProps": {
            "type": "object",
            "properties": {},
            "additionalProperties": false,
            "title": "Spacer",
            "description": "Vertical spacing."
        },
        "spacerBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "spacer",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/spacerConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "dividerConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "thickness": {
                    "type": "integer",
                    "default": 1
                },
                "lineColor": {
                    "type": "string",
                    "pattern": "^#[0-9A-Fa-f]{3,8}$",
                    "default": "#d1d5db"
                },
                "style": {
                    "type": "string",
                    "default": "solid"
                }
            },
            "unevaluatedProperties": false
        },
        "dividerProps": {
            "type": "object",
            "properties": {},
            "additionalProperties": false,
            "title": "Divider",
            "description": "A horizontal rule."
        },
        "dividerBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "divider",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/dividerConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "keyValueConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "labelWidth": {
                    "type": "string",
                    "default": "30mm"
                }
            },
            "unevaluatedProperties": false
        },
        "keyValueProps": {
            "type": "object",
            "properties": {
                "entries": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "label": {
                                "type": "string",
                                "examples": [
                                    "Label"
                                ]
                            },
                            "value": {
                                "type": "string",
                                "examples": [
                                    "Value"
                                ]
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "label",
                            "value"
                        ]
                    },
                    "examples": [
                        [
                            {
                                "label": "Label",
                                "value": "Value"
                            }
                        ]
                    ],
                    "default": []
                }
            },
            "additionalProperties": false,
            "title": "Key / Value"
        },
        "keyValueBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "key-value",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/keyValueConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "tableConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "columnAlignments": {
                    "type": [
                        "array",
                        "null"
                    ],
                    "items": {
                        "type": "string"
                    }
                },
                "columnWidths": {
                    "type": [
                        "array",
                        "null"
                    ],
                    "items": {
                        "type": [
                            "integer",
                            "string"
                        ]
                    }
                },
                "style": {
                    "type": "string",
                    "default": "striped"
                }
            },
            "unevaluatedProperties": false
        },
        "tableProps": {
            "type": "object",
            "properties": {
                "headers": {
                    "type": "array",
                    "examples": [
                        [
                            "Column A",
                            "Column B"
                        ]
                    ]
                },
                "rows": {
                    "type": "array",
                    "examples": [
                        [
                            [
                                "A1",
                                "B1"
                            ],
                            [
                                "A2",
                                "B2"
                            ]
                        ]
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "headers",
                "rows"
            ],
            "title": "Table"
        },
        "tableBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "table",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/tableConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "row": {
            "type": "object",
            "required": [
                "blocks"
            ],
            "properties": {
                "blocks": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/block"
                    }
                },
                "gap": {
                    "type": "integer",
                    "minimum": 0
                },
                "columnWidths": {
                    "type": "array",
                    "items": {
                        "type": [
                            "integer",
                            "string"
                        ]
                    }
                }
            },
            "additionalProperties": false
        },
        "block": {
            "oneOf": [
                {
                    "$ref": "#/$defs/headingBlock"
                },
                {
                    "$ref": "#/$defs/textBlock"
                },
                {
                    "$ref": "#/$defs/htmlBlock"
                },
                {
                    "$ref": "#/$defs/imageBlock"
                },
                {
                    "$ref": "#/$defs/spacerBlock"
                },
                {
                    "$ref": "#/$defs/dividerBlock"
                },
                {
                    "$ref": "#/$defs/keyValueBlock"
                },
                {
                    "$ref": "#/$defs/tableBlock"
                }
            ]
        }
    },
    "examples": [
        {
            "title": "Invoice",
            "version": 1,
            "config": {
                "page": {
                    "format": "A4"
                }
            },
            "rows": [
                {
                    "blocks": [
                        {
                            "type": "heading",
                            "id": "company",
                            "config": {
                                "level": 1,
                                "width": "60%"
                            }
                        },
                        {
                            "type": "key-value",
                            "id": "invoice-meta",
                            "config": {
                                "align": "right",
                                "width": "40%"
                            }
                        }
                    ]
                },
                {
                    "blocks": [
                        {
                            "type": "key-value",
                            "id": "from",
                            "config": {
                                "width": "50%"
                            }
                        },
                        {
                            "type": "key-value",
                            "id": "to",
                            "config": {
                                "width": "50%"
                            }
                        }
                    ]
                },
                {
                    "blocks": [
                        {
                            "type": "divider",
                            "id": "rule"
                        }
                    ]
                },
                {
                    "blocks": [
                        {
                            "type": "table",
                            "id": "items"
                        }
                    ]
                },
                {
                    "blocks": [
                        {
                            "type": "key-value",
                            "id": "totals",
                            "config": {
                                "align": "right"
                            }
                        }
                    ]
                },
                {
                    "blocks": [
                        {
                            "type": "text",
                            "id": "footer"
                        }
                    ]
                }
            ]
        }
    ]
}
