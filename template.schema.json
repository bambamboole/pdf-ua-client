{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://pdfuakit.com/schemas/pdf-ua-client-template-v1.json",
    "type": "object",
    "required": [
        "version",
        "config",
        "rows"
    ],
    "properties": {
        "version": {
            "const": 1,
            "type": "integer"
        },
        "config": {
            "$ref": "#/$defs/templateConfig"
        },
        "rows": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/row"
            }
        },
        "data": {
            "type": "object",
            "properties": {
                "example": {
                    "type": "object",
                    "additionalProperties": true
                },
                "defaults": {
                    "type": "object",
                    "additionalProperties": true
                },
                "constants": {
                    "type": "object",
                    "additionalProperties": true
                }
            },
            "additionalProperties": false
        },
        "attachments": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/attachment"
            }
        },
        "attachmentRequirements": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/attachmentRequirement"
            }
        }
    },
    "$defs": {
        "blockBase": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                }
            }
        },
        "typographyConfig": {
            "type": "object",
            "properties": {
                "family": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "Inter",
                        "Georgia"
                    ],
                    "enumNames": [
                        "Inter",
                        "Georgia"
                    ],
                    "title": "Font family",
                    "description": "Registered font key used for this text."
                },
                "size": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "title": "Font size",
                    "description": "Font size in points."
                },
                "weight": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "enum": [
                        300,
                        400,
                        500,
                        600,
                        700
                    ],
                    "title": "Font weight",
                    "description": "Numeric font weight."
                },
                "align": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "left",
                        "center",
                        "right"
                    ],
                    "title": "Text alignment",
                    "description": "Text alignment for this typography scope."
                },
                "color": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "title": "Text color",
                    "description": "CSS color value used for text."
                }
            },
            "additionalProperties": false
        },
        "spacingConfig": {
            "type": "object",
            "properties": {
                "top": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "title": "Top",
                    "description": "Top spacing in millimetres.",
                    "minimum": 0
                },
                "right": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "title": "Right",
                    "description": "Right spacing in millimetres.",
                    "minimum": 0
                },
                "bottom": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "title": "Bottom",
                    "description": "Bottom spacing in millimetres.",
                    "minimum": 0
                },
                "left": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "title": "Left",
                    "description": "Left spacing in millimetres.",
                    "minimum": 0
                }
            },
            "additionalProperties": false
        },
        "blockConfig": {
            "type": "object",
            "properties": {
                "typography": {
                    "$ref": "#/$defs/typographyConfig",
                    "title": "Typography",
                    "description": "Overrides the page typography for this block."
                },
                "spacing": {
                    "$ref": "#/$defs/spacingConfig",
                    "title": "Spacing",
                    "description": "Outer spacing around this block in millimetres."
                },
                "width": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "title": "Width",
                    "description": "CSS width for this block, such as 50%, 80mm, or auto."
                },
                "align": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "enum": [
                        "left",
                        "center",
                        "right"
                    ],
                    "title": "Alignment",
                    "description": "Horizontal placement of this block within its row cell."
                }
            }
        },
        "headingConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "level": {
                    "type": "integer",
                    "title": "Level",
                    "description": "Heading level from 1 for the largest heading through 6 for the smallest.",
                    "minimum": 1,
                    "maximum": 6,
                    "default": 2
                }
            },
            "unevaluatedProperties": false
        },
        "headingProps": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string",
                    "examples": [
                        "Invoice 2026-001"
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "text"
            ],
            "title": "Heading",
            "description": "A section heading (h1\u2013h6)."
        },
        "headingBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "heading",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/headingConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "textProps": {
            "type": "object",
            "properties": {
                "text": {
                    "type": "string",
                    "examples": [
                        "Thank you for your business."
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "text"
            ],
            "title": "Text",
            "description": "A paragraph of text."
        },
        "textBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "text",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/blockConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "htmlProps": {
            "type": "object",
            "properties": {
                "html": {
                    "type": "string",
                    "examples": [
                        "<p>Custom HTML</p>"
                    ]
                }
            },
            "additionalProperties": false,
            "required": [
                "html"
            ],
            "title": "HTML",
            "description": "Raw HTML escape hatch."
        },
        "htmlBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "html",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/blockConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "imageConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "maxHeight": {
                    "type": "integer",
                    "title": "Maximum height",
                    "description": "Maximum rendered image height in pixels.",
                    "minimum": 1,
                    "default": 60
                }
            },
            "unevaluatedProperties": false
        },
        "imageProps": {
            "type": "object",
            "properties": {
                "src": {
                    "type": "string",
                    "title": "Image source",
                    "description": "Public image URL or uploaded image data URL. Uploads are limited to 200 KB.",
                    "maxLength": 280000,
                    "examples": [
                        "data:image/svg+xml;base64,"
                    ]
                },
                "alt": {
                    "type": "string",
                    "title": "Alt text",
                    "description": "Alternative text for screen readers and PDF accessibility.",
                    "examples": [
                        "Logo"
                    ],
                    "default": ""
                }
            },
            "additionalProperties": false,
            "required": [
                "src"
            ],
            "title": "Image"
        },
        "imageBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "image",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/imageConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "spacerConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "height": {
                    "type": "integer",
                    "title": "Height",
                    "description": "Spacer height in millimetres.",
                    "minimum": 0,
                    "default": 5
                }
            },
            "unevaluatedProperties": false
        },
        "spacerProps": {
            "type": "object",
            "properties": {},
            "additionalProperties": false,
            "title": "Spacer",
            "description": "Vertical spacing."
        },
        "spacerBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "spacer",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/spacerConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "dividerConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "thickness": {
                    "type": "integer",
                    "title": "Thickness",
                    "description": "Line thickness in points.",
                    "default": 1
                },
                "lineColor": {
                    "type": "string",
                    "title": "Line color",
                    "description": "Hex color used for the divider line.",
                    "pattern": "^#[0-9A-Fa-f]{3,8}$",
                    "default": "#d1d5db"
                },
                "style": {
                    "type": "string",
                    "title": "Line style",
                    "description": "CSS border style used for the divider line.",
                    "default": "solid"
                }
            },
            "unevaluatedProperties": false
        },
        "dividerProps": {
            "type": "object",
            "properties": {},
            "additionalProperties": false,
            "title": "Divider",
            "description": "A horizontal rule."
        },
        "dividerBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "divider",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/dividerConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "keyValueConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "labelWidth": {
                    "type": "string",
                    "title": "Label width",
                    "description": "CSS width for the first column containing labels.",
                    "default": "30mm"
                },
                "fields": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "key": {
                                "type": "string",
                                "title": "Key",
                                "description": "Runtime data key used for this row value.",
                                "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
                            },
                            "label": {
                                "type": "string",
                                "title": "Label",
                                "description": "Label rendered in the first column."
                            }
                        },
                        "additionalProperties": false
                    },
                    "title": "Fields",
                    "description": "Fixed key/label rows rendered by this block. Values come from runtime data by key.",
                    "default": []
                }
            },
            "unevaluatedProperties": false
        },
        "keyValueProps": {
            "type": "object",
            "properties": {
                "values": {
                    "type": "array",
                    "default": []
                }
            },
            "additionalProperties": false,
            "title": "Key / Value"
        },
        "keyValueBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "key-value",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/keyValueConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "tableConfig": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockConfig"
                }
            ],
            "properties": {
                "numberRows": {
                    "type": "boolean",
                    "title": "Number rows",
                    "description": "Render an auto-incrementing row number column before configured data columns.",
                    "default": false
                },
                "columns": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "key": {
                                "type": "string",
                                "title": "Key",
                                "description": "Runtime data key used for this table column.",
                                "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
                            },
                            "label": {
                                "type": "string",
                                "title": "Label",
                                "description": "Header label rendered for this table column."
                            },
                            "align": {
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "enum": [
                                    "left",
                                    "center",
                                    "right"
                                ],
                                "title": "Alignment",
                                "description": "Text alignment for this table column."
                            },
                            "width": {
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "title": "Width",
                                "description": "Column width as millimetres or a CSS width value."
                            }
                        },
                        "additionalProperties": false
                    },
                    "title": "Columns",
                    "description": "Fixed table columns. Runtime data uses these keys for each row object.",
                    "default": []
                },
                "style": {
                    "type": "string",
                    "title": "Style",
                    "description": "Visual table style preset.",
                    "default": "striped"
                }
            },
            "unevaluatedProperties": false
        },
        "tableProps": {
            "type": "object",
            "properties": {
                "rows": {
                    "type": "array"
                }
            },
            "additionalProperties": false,
            "required": [
                "rows"
            ],
            "title": "Table"
        },
        "tableBlock": {
            "allOf": [
                {
                    "$ref": "#/$defs/blockBase"
                }
            ],
            "properties": {
                "type": {
                    "const": "table",
                    "type": "string"
                },
                "config": {
                    "$ref": "#/$defs/tableConfig"
                }
            },
            "unevaluatedProperties": false
        },
        "row": {
            "type": "object",
            "required": [
                "blocks"
            ],
            "properties": {
                "blocks": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/block"
                    }
                },
                "gap": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "additionalProperties": false
        },
        "block": {
            "oneOf": [
                {
                    "$ref": "#/$defs/headingBlock"
                },
                {
                    "$ref": "#/$defs/textBlock"
                },
                {
                    "$ref": "#/$defs/htmlBlock"
                },
                {
                    "$ref": "#/$defs/imageBlock"
                },
                {
                    "$ref": "#/$defs/spacerBlock"
                },
                {
                    "$ref": "#/$defs/dividerBlock"
                },
                {
                    "$ref": "#/$defs/keyValueBlock"
                },
                {
                    "$ref": "#/$defs/tableBlock"
                }
            ]
        },
        "attachment": {
            "type": "object",
            "required": [
                "name",
                "contentBase64",
                "mimeType"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "title": "File name",
                    "description": "File name shown in the PDF attachment list."
                },
                "contentBase64": {
                    "type": "string",
                    "minLength": 1,
                    "contentEncoding": "base64",
                    "title": "Content",
                    "description": "Base64 encoded attachment content."
                },
                "mimeType": {
                    "type": "string",
                    "minLength": 1,
                    "title": "MIME type",
                    "description": "Attachment media type, for example application/xml."
                },
                "description": {
                    "type": "string",
                    "title": "Description",
                    "description": "Optional human-readable attachment description."
                },
                "relationship": {
                    "type": "string",
                    "enum": [
                        "Source",
                        "Data",
                        "Alternative",
                        "Supplement",
                        "Unspecified"
                    ],
                    "title": "Relationship",
                    "description": "PDF associated-file relationship."
                }
            },
            "additionalProperties": false
        },
        "attachmentRequirement": {
            "type": "object",
            "required": [
                "id",
                "name",
                "mimeType"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1,
                    "title": "Attachment id",
                    "description": "Runtime data key used to provide this attachment."
                },
                "name": {
                    "type": "string",
                    "minLength": 1,
                    "title": "File name",
                    "description": "File name shown in the PDF attachment list."
                },
                "mimeType": {
                    "type": "string",
                    "minLength": 1,
                    "title": "MIME type",
                    "description": "Attachment media type, for example application/xml."
                },
                "description": {
                    "type": "string",
                    "title": "Description",
                    "description": "Optional human-readable attachment description."
                },
                "relationship": {
                    "type": "string",
                    "enum": [
                        "Source",
                        "Data",
                        "Alternative",
                        "Supplement",
                        "Unspecified"
                    ],
                    "title": "Relationship",
                    "description": "PDF associated-file relationship."
                },
                "required": {
                    "type": "boolean",
                    "title": "Required",
                    "description": "Require this attachment in the runtime data contract.",
                    "default": true
                }
            },
            "additionalProperties": false
        },
        "pageFooterConfig": {
            "type": "object",
            "properties": {
                "repeat": {
                    "type": "boolean",
                    "title": "Repeat",
                    "description": "Repeat the footer on every rendered page.",
                    "default": true
                },
                "rows": {
                    "type": "array",
                    "title": "Rows",
                    "description": "Footer rows rendered after the page body.",
                    "items": {
                        "$ref": "#/$defs/row"
                    },
                    "default": []
                }
            },
            "additionalProperties": false
        },
        "pageNumbersConfig": {
            "type": "object",
            "properties": {
                "enabled": {
                    "type": "boolean",
                    "title": "Enabled",
                    "description": "Show page numbers in the page footer.",
                    "default": false
                },
                "position": {
                    "type": "string",
                    "enum": [
                        "left",
                        "center",
                        "right"
                    ],
                    "title": "Position",
                    "description": "Footer position used for page numbers.",
                    "default": "center"
                }
            },
            "additionalProperties": false
        },
        "pageConfig": {
            "type": "object",
            "properties": {
                "format": {
                    "type": "string",
                    "enum": [
                        "A4",
                        "A5",
                        "Letter",
                        "Legal",
                        "ParcelLabel4x6"
                    ],
                    "title": "Format",
                    "description": "Physical page size used for rendering.",
                    "default": "A4"
                },
                "locale": {
                    "type": "string",
                    "title": "Locale",
                    "description": "Document locale used for language-aware rendering.",
                    "default": "de_DE"
                },
                "margins": {
                    "$ref": "#/$defs/spacingConfig",
                    "title": "Margins",
                    "description": "Page margins in millimetres."
                },
                "pageNumbers": {
                    "$ref": "#/$defs/pageNumbersConfig",
                    "title": "Pagination",
                    "description": "Page number display settings."
                },
                "footer": {
                    "$ref": "#/$defs/pageFooterConfig",
                    "title": "Footer",
                    "description": "Repeated page footer rows."
                }
            },
            "additionalProperties": false
        },
        "templateConfig": {
            "type": "object",
            "properties": {
                "page": {
                    "$ref": "#/$defs/pageConfig",
                    "title": "Page",
                    "description": "Document page setup."
                },
                "typography": {
                    "$ref": "#/$defs/typographyConfig",
                    "title": "Typography",
                    "description": "Default typography inherited by blocks."
                }
            },
            "additionalProperties": false
        }
    }
}
